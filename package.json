{
  "name": "next-sanity-neon-drizzle",
  "version": "0.1.0",
  "author": {
    "name": "Mike Grace",
    "email": "mikegrace274@gmail.com",
    "url": "https://mike-grace.com"
  },
  "private": true,
  "scripts": {
    "dev": "next dev --port 7890",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix src --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx}",
    "test:lint": "bunx eslint src --cache --cache-location .eslintcache",
    "test:prettier": "prettier --check ./src",
    "prepare": "husky",
    "ts:check": "bunx tsc --noEmit",
    "ts:schema": "bunx sanity schema extract --enforce-required-fields --workspace development",
    "ts:gen": "bunx sanity typegen generate",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:drop": "drizzle-kit drop",
    "db:push": "bunx drizzle-kit push",
    "db:gen": "bunx drizzle-kit generate",
    "db:migrate": "cross-env DB_MIGRATING=true bun run src/db/migrate.ts",
    "db:seed": "cross-env DB_SEEDING=true bun run src/db/seeds/seedAll.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@focus-reactive/sanity-plugin-inline-svg-input": "^1.3.0",
    "@marsidev/react-turnstile": "^1.5.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@upstash/redis": "^1.37.0",
    "argon2": "^0.44.0",
    "bufferutil": "^4.1.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.6.0",
    "next": "^16.2.2",
    "next-cloudinary": "^6.17.5",
    "next-sanity": "^12.2.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^5.19.0",
    "sanity-plugin-cloudinary": "^1.4.1",
    "server-only": "^0.0.1",
    "styled-components": "^6.3.12",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.39.4",
    "@happy-dom/global-registrator": "^20.8.9",
    "@sanity/color-input": "^6.0.4",
    "@sanity/eslint-config-studio": "^6.0.0",
    "@sanity/vision": "^5.19.0",
    "@storybook/addon-a11y": "10.3.3",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-onboarding": "10.3.3",
    "@storybook/nextjs-vite": "10.3.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/jest-axe": "^3.5.9",
    "@types/jsdom": "^28.0.1",
    "@types/pg": "^8.20.0",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "axe-core": "^4.11.2",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "eslint": "9.36.0",
    "eslint-config-next": "16.2.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-storybook": "10.3.3",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "10.3.3",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.(json|js|jsx|ts|tsx|html|css|md)": [
      "prettier --write"
    ],
    "*.(js|jsx|ts|tsx)": [
      "eslint --fix"
    ]
  }
}
